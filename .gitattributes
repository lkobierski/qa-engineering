# Documentation files should not dominate language statistics
*.md linguist-documentation

# JMeter files
*.jmx linguist-detectable=true

*.html linguist-detectable=false
*.css linguist-detectable=true
*.json linguist-detectable=true
*.jtl linguist-detectable=true

.github/workflows/*.yml linguist-detectable=true

# Keep JavaScript as detectable project language
*.js linguist-detectable=true