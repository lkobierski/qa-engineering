      "name": "Users",
      "item": [
        {
          "name": "GET List Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response contains users list\", function () {\r",
                  "    const response = pm.response.json();\r",
                  "\r",
                  "    pm.expect(response).to.have.property(\"page\");\r",
                  "    pm.expect(response).to.have.property(\"data\");\r",
                  "    pm.expect(response.data).to.be.an(\"array\");\r",
                  "    pm.expect(response.data.length).to.be.greaterThan(0);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"User object contains required fields\", function () {\r",
                  "    const response = pm.response.json();\r",
                  "    const user = response.data[0];\r",
                  "\r",
                  "    pm.expect(user).to.have.property(\"id\");\r",
                  "    pm.expect(user).to.have.property(\"email\");\r",
                  "    pm.expect(user).to.have.property(\"first_name\");\r",
                  "    pm.expect(user).to.have.property(\"last_name\");\r",
                  "    pm.expect(user).to.have.property(\"avatar\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
